{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>hmcts/.github:renovate-config"
  ],
  "labels": ["dependencies"],
  "helm-requirements":
  {
    "fileMatch": ["\\Chart.yaml|requirements.yaml$"],
    "aliases": {
      "hmctsprod": "https://hmctsprod.azurecr.io/helm/v1/repo/"
    }
  }
}
